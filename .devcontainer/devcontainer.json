{
	"name": "SilRok AI Server",
	"dockerComposeFile": "./docker-compose.yml",
	"service": "dev",
	"workspaceFolder": "/workspaces/dev",
	"features": {
		"ghcr.io/devcontainers/features/github-cli:1": {}
	},
	"customizations": {
		"vscode": {
			"extensions": [
				"ms-python.vscode-pylance",
				"ms-python.python", 
				"ms-python.debugpy",
				"rsip-vision.nvidia-smi-plus",
				"ms-vscode.azurecli",
				"ms-vscode.powershell",
				"hashicorp.terraform",
				"tfsec.tfsec",
				"esbenp.prettier-vscode",
				"ms-toolsai.jupyter"
			]
		}
	}
}
