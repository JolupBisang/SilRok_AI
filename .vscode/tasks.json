{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "Run Main Python File",
            "type": "shell",
            "command": "${config:python.defaultInterpreterPath}",
            "args": [
                // "${workspaceFolder}/${relativeFile}"
                "${workspaceFolder}/app/main.py"
            ],
            "presentation": {
                "echo": true,
                "reveal": "always",
                "focus": false,
                "panel": "dedicated",
                "showReuseMessage": true,
                "clear": true
            },
            "group": {
                "kind": "build",
                "isDefault": true
            },
            "options": {
                "env": {
                    "PYTHONPATH":"${workspaceFolder}/app:${workspaceFolder}/RTWhisper/modules"
                }
            },
            "problemMatcher": []
        },
    ]
}
